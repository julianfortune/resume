\def\scimisc@cvname{}
\def\scimisc@cvpersonalinfo{}
\def\cvinfosep{// {}}

\newcommand{\cvname}[1]{\def\scimisc@cvname{#1}}
\newcommand{\cvpersonalinfo}[1]{\def\scimisc@cvpersonalinfo{#1}}

\newcommand{\cvnamefont}{\huge\bfseries}
\newcommand{\cvpersonalinfofont}{\normalsize\ttfamily}

\newcommand{\makecvtitle}{%
  \begin{center}
      {\cvnamefont\MakeTextUppercase{\scimisc@cvname}\par}
      {\cvpersonalinfofont\scimisc@cvpersonalinfo\par}
  \end{center}\medskip
}

\newcommand{\experience}[3]{%
  % \needspace{4\baselineskip}%
  \vspace{5pt}%
  \textbf{#1} --- #2\hfill#3%
  \par\vspace{-4pt}
}

\newcommand{\link}[2]{%
  \href{#1}{\underline{\smash{#2}}}
}

% Adjust the formatting of section headers
\titleformat{\section}%
  {\Large}{\thesection}{0pt}{\MakeTextUppercase{#1}}[{\color{gray}\titlerule[0.5pt]}]
\titlespacing{\section}{0pt}{5pt}{5pt}  % left / above / below


